---
// src/components/Roadmap.astro
const events = [
  {
    year: "2021",
    title: "Le Déclic",
    description: "Début de l'aventure entrepreneuriale. Premiers pas dans la création de contenu.",
  },
  {
    year: "2022",
    title: "Lancement YouTube",
    description: "Première vidéo publiée. Construction d'une communauté engagée.",
  },
  {
    year: "2023",
    title: "Expansion",
    description: "Développement des formations et diversification des revenus.",
  },
  {
    year: "2024",
    title: "Nouveaux Horizons",
    description: "Passage à l'échelle. Lancement de nouveaux projets et collaborations.",
  },
];
---

<section class="parcours" id="qui-suis-je">
  <!-- Qui suis-je intro -->
  <div class="parcours__intro">
    <div class="parcours__image">
      <img src="/images/Profile.png" alt="Nass Riviera" />
    </div>
    <div class="parcours__about">
      <h2 class="parcours__title">Qui suis-je ?</h2>
      <p class="parcours__description">
        Je suis Nass Riviera, créateur de contenu et entrepreneur.
        Je partage mon parcours et mes stratégies pour aider ceux qui veulent
        se lancer dans l'entrepreneuriat et la création de contenu.
      </p>
    </div>
  </div>

  <!-- Divider -->
  <div class="parcours__divider"></div>

  <!-- Timeline -->
  <h3 class="roadmap__title">Mon Parcours</h3>
  <div class="roadmap__timeline">
    <div class="roadmap__line"></div>
    {events.map((event) => (
      <div class="roadmap__item">
        <div class="roadmap__node"></div>
        <div class="roadmap__card">
          <span class="roadmap__year">{event.year}</span>
          <h4 class="roadmap__card-title">{event.title}</h4>
          <p class="roadmap__card-desc">{event.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .parcours {
    background-color: var(--color-bg-elevated);
  }

  /* --- Qui suis-je intro --- */
  .parcours__intro {
    max-width: var(--max-w-content);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
    text-align: center;
  }

  .parcours__image {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--color-cyan);
    flex-shrink: 0;
    box-shadow: var(--shadow-glow-cyan);
  }

  .parcours__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .parcours__title {
    font-size: 1.75rem;
    color: var(--color-cyan);
    margin-bottom: var(--space-md);
  }

  .parcours__description {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.8;
    max-width: var(--max-w-text);
  }

  @media (min-width: 768px) {
    .parcours__intro {
      flex-direction: row;
      text-align: left;
      gap: var(--space-3xl);
    }

    .parcours__image {
      width: 220px;
      height: 220px;
    }
  }

  /* --- Divider --- */
  .parcours__divider {
    max-width: 660px;
    margin: var(--space-3xl) auto;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--color-border),
      transparent
    );
  }

  /* --- Timeline --- */
  .roadmap__title {
    text-align: center;
    font-size: 1.5rem;
    color: var(--color-cyan);
    margin-bottom: var(--space-2xl);
  }

  .roadmap__timeline {
    position: relative;
    max-width: 660px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .roadmap__line {
    position: absolute;
    left: 7px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--color-cyan), var(--color-orange));
    opacity: 0.4;
  }

  .roadmap__item {
    position: relative;
    display: flex;
    gap: var(--space-lg);
    align-items: flex-start;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .roadmap__item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .roadmap__item:nth-child(2) { transition-delay: 0.1s; }
  .roadmap__item:nth-child(3) { transition-delay: 0.2s; }
  .roadmap__item:nth-child(4) { transition-delay: 0.3s; }
  .roadmap__item:nth-child(5) { transition-delay: 0.4s; }

  .roadmap__node {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-cyan), var(--color-orange));
    box-shadow: 0 0 12px rgba(0, 212, 255, 0.4);
    transition: transform 0.2s;
  }

  .roadmap__item:hover .roadmap__node {
    transform: scale(1.3);
  }

  .roadmap__card {
    flex: 1;
    padding: var(--space-lg);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.3s, border-color 0.3s;
  }

  .roadmap__item:hover .roadmap__card {
    box-shadow: var(--shadow-elevated);
    border-color: rgba(0, 212, 255, 0.2);
  }

  .roadmap__year {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-orange);
  }

  .roadmap__card-title {
    margin-top: var(--space-xs);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .roadmap__card-desc {
    margin-top: var(--space-sm);
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }
</style>

<script>
  const items = document.querySelectorAll('.roadmap__item');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    },
    { threshold: 0.15 }
  );

  items.forEach((item) => observer.observe(item));
</script>
