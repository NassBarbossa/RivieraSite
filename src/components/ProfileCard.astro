---

<section class="profile-section">
  <!-- Desktop -->
  <div class="profile profile--desktop">
    <div class="profile__image">
      <img src="/images/Profile.png" alt="Nass Riviera" />
    </div>
    <div class="profile__card">
      <h2 class="profile__name">Nass Riviera</h2>
      <p class="profile__title">Entrepreneur & VibeCoder</p>
      <p class="profile__bio">
        Entrepreneur & Investisseur depuis 2017, j'ai décidé de tout reconstruire grâce au VibeCoding. Je partage mon parcours, mes outils et mon écosystème en toute transparence.
      </p>
      <div class="profile__socials">
        {socials.map((s) => (
          <a href={s.url} target="_blank" rel="noopener" aria-label={s.name} class="profile__social">
            <Fragment set:html={s.svg} />
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Mobile -->
  <div class="profile profile--mobile">
    <div class="profile__image profile__image--mobile">
      <img src="/images/Profile.png" alt="Nass Riviera" />
    </div>
    <div class="profile__content-mobile">
      <h2 class="profile__name">Nass Riviera</h2>
      <p class="profile__title">Entrepreneur & VibeCoder</p>
      <p class="profile__bio">
        Entrepreneur & Investisseur depuis 2017, j'ai décidé de tout reconstruire grâce au VibeCoding. Je partage mon parcours, mes outils et mon écosystème en toute transparence.
      </p>
      <div class="profile__socials profile__socials--center">
        {socials.map((s) => (
          <a href={s.url} target="_blank" rel="noopener" aria-label={s.name} class="profile__social">
            <Fragment set:html={s.svg} />
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .profile-section {
    padding: 0 var(--space-lg) var(--space-3xl);
  }

  /* --- Desktop --- */
  .profile--desktop {
    display: none;
    max-width: var(--max-w-content);
    margin: 0 auto;
    align-items: center;
  }

  @media (min-width: 768px) {
    .profile--desktop {
      display: flex;
    }
    .profile--mobile {
      display: none;
    }
  }

  /* --- Mobile --- */
  .profile--mobile {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 380px;
    margin: 0 auto;
    text-align: center;
  }

  @media (min-width: 768px) {
    .profile--mobile {
      display: none;
    }
  }

  /* --- Image --- */
  .profile__image {
    width: 400px;
    height: 400px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    flex-shrink: 0;
  }

  .profile__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }

  .profile__image--mobile {
    width: 100%;
    aspect-ratio: 1;
    height: auto;
    margin-bottom: var(--space-xl);
  }

  /* --- Overlapping card (desktop) --- */
  .profile__card {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    margin-left: -80px;
    z-index: 1;
    flex: 1;
    max-width: 540px;
    box-shadow: var(--shadow-elevated);
  }

  /* --- Mobile content --- */
  .profile__content-mobile {
    padding: 0 var(--space-md);
  }

  /* --- Typography --- */
  .profile__name {
    font-family: var(--font-headline);
    font-size: 1.6rem;
    font-weight: 700;
    color: white;
    margin-bottom: var(--space-sm);
  }

  .profile__title {
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-cyan);
    margin-bottom: var(--space-lg);
  }

  .profile__bio {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-xl);
  }

  /* --- Social links --- */
  .profile__socials {
    display: flex;
    gap: var(--space-md);
  }

  .profile__socials--center {
    justify-content: center;
  }

  .profile__social {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background-color: transparent;
    border: none;
    border-radius: 50%;
    color: white;
    text-decoration: none;
    transition: transform 0.2s, background-color 0.3s;
  }

  .profile__social svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  .profile__social:hover {
    transform: scale(1.1);
    background-color: var(--color-cyan);
    color: var(--color-bg);
  }
</style>
